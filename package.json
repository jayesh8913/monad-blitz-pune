{
  "name": "monad-trading-agent-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/frontend",
    "packages/backend",
    "packages/contracts"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w packages/frontend",
